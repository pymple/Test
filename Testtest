local function TweenTo(enemy)
    if not enemy then return end
    local goal,look=GetGoalForEnemy(enemy) if not goal then return end
    local hrp=PlayerHRP() if not hrp then return end
    local d=(hrp.Position-goal).Magnitude
    if d>400 then return end
    if F.MoveMode=="Teleport" then
        StopTw()
        hrp.CFrame=CFrame.new(goal,look or goal)
        LockTarget=enemy TweenOn=false TweenTarget=nil HoverPos=goal
        return
    end
    if TweenTarget~=enemy then StopTw() end
    local d=(hrp.Position-goal).Magnitude
    if d<5 then LockTarget=enemy TweenOn=false TweenTarget=nil HoverPos=goal return end
    if TweenOn and TweenTarget==enemy then return end
    StopTw() TweenOn=true TweenTarget=enemy LockTarget=nil
    local cf=CFrame.new(goal,look or goal)
    local dur=math.clamp(d/math.max(F.TweenSpeed,20),0.05,8)
    ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    ATweenConn=ATween.Completed:Connect(function() ATween=nil ATweenConn=nil TweenOn=false TweenTarget=nil LockTarget=enemy HoverPos=goal end)
    ATween:Play()
    local t=tick()
    while TweenOn and TweenTarget==enemy and tick()-t<dur+0.5 do task.wait(0.05) end
end
local function TweenToPoint(goal)
    local hrp=PlayerHRP() if not hrp then return end
