    ATween=TweenService:Create(hrp,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=cf})
    ATweenConn=ATween.Completed:Connect(function() ATween=nil ATweenConn=nil TweenOn=false HoverPos=goal end)
