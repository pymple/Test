        for _,b in ipairs(SummonBosses) do
            if BSF[b.Name] or SummonBossCommitted[b.Name] then
                local m=CheckSummonBoss(b.Name)
                if m and SummonBossPosValid(m) then return b.Name,m end
            end
        end
        task.wait(0.05)
    end
    return nil,nil
end
local function DoSummonBossTick()
    -- Determine which bosses are enabled and what islands they need
    local function GetNeededIslands()
        local islands={}
        for _,b in ipairs(SummonBosses) do
            if BSF[b.Name] or SummonBossCommitted[b.Name] then
                local isl=GetSummonBossIsland(b.Name)
                islands[isl]=true
            end
        end
        return islands
    end
    -- Pick based on FIFO commit order, fallback to nearest alive
    local function PickBestTarget()
        local bestName,bestOrder=nil,math.huge
        local hrp=PlayerHRP()
        for _,b in ipairs(SummonBosses) do
            if SummonBossCommitted[b.Name] then
                local m=CheckSummonBoss(b.Name)
                if m and SummonBossPosValid(m) then
                    local ord=SummonBossCommitted[b.Name]
                    if type(ord)=="number" and ord<bestOrder then bestOrder=ord bestName=b.Name end
                end
            end
        end
        if bestName then return bestName end
        -- Fallback: nearest alive committed/enabled
        local bestDist=math.huge
        for _,b in ipairs(SummonBosses) do
            if BSF[b.Name] or SummonBossCommitted[b.Name] then
                local m=CheckSummonBoss(b.Name)
                if m and SummonBossPosValid(m) then
                    if not hrp then return b.Name end
                    local p=ModelPos(m)
                    local d=p and (hrp.Position-p).Magnitude or math.huge
                    if d<bestDist then bestDist=d bestName=b.Name end
                end
            end
        end
        return bestName
    end
    -- Summon enabled bosses on the current island that haven't been summoned yet
    local function SummonAllEnabled()
        for _,b in ipairs(SummonBosses) do
            if BSF[b.Name] and not SummonBossCommitted[b.Name] and GetSummonBossIsland(b.Name)==SummonBossCurrentIsland then
                FireSummonBoss(b.Name)
                SummonBossOrder=SummonBossOrder+1
                SummonBossCommitted[b.Name]=SummonBossOrder
                task.wait(0.1)
            end
        end
    end
    -- Phase 1: TP to island if needed
    if not SummonBossTPDone then
        if tick()-LastSummonBossTP<4 then task.wait(0.2) return end
        -- Figure out first island to go to: prioritize island of earliest committed boss, or Boss island
        local targetIsland=BOSS_ISLAND_PORTAL
        local bestOrd=math.huge
        for _,b in ipairs(SummonBosses) do
            if BSF[b.Name] then
                local isl=GetSummonBossIsland(b.Name)
                local ord=SummonBossCommitted[b.Name]
                if type(ord)=="number" and ord<bestOrd then bestOrd=ord targetIsland=isl end
            end
        end
        -- If no committed yet, go to Boss island first (most bosses are there)
        if bestOrd==math.huge then
            local hasBossIsland,hasOther=false,false
            for _,b in ipairs(SummonBosses) do
                if BSF[b.Name] then
                    if GetSummonBossIsland(b.Name)==BOSS_ISLAND_PORTAL then hasBossIsland=true
                    else hasOther=true end
                end
            end
            if hasBossIsland then targetIsland=BOSS_ISLAND_PORTAL
            elseif hasOther then
                for _,b in ipairs(SummonBosses) do
                    if BSF[b.Name] then targetIsland=GetSummonBossIsland(b.Name) break end
                end
            end
        end
        LastSummonBossTP=tick()
        local displayIsland=PortalDisplayName(targetIsland)
        Notify.new({Title="Summon Boss",Content="Teleporting to "..displayIsland,Duration=2,Icon=ICON})
        StopTw() HoverPos=nil ClearTgt()
        local _hrpBefore=PlayerHRP()
        local posBefore=_hrpBefore and _hrpBefore.Position
        ForceTP(targetIsland)
        task.wait(0.9)
        -- Verify TP worked; retry once if position barely changed
        local _hrpAfter=PlayerHRP()
        if posBefore and _hrpAfter and (posBefore-_hrpAfter.Position).Magnitude<30 then
            ForceTP(targetIsland)
            task.wait(1.0)
        end
        SummonBossCurrentIsland=targetIsland
        local _hrp=PlayerHRP() if _hrp then HoverPos=_hrp.Position end
        -- Summon bosses for this island
        SummonAllEnabled()
        local nextName,nextModel=AcquireSummonBossFast(nil,1.0)
        SummonBossTPDone=true SummonBossTarget=nextName
        if nextModel then CurTarget=nextModel end
        return
    end
    -- Phase 2: find a target
    if not SummonBossTarget then
        SummonBossTarget=PickBestTarget()
        if not SummonBossTarget then
            -- Track stuck time — if no target found for too long, exit summon mode
            if SummonBossStuckSince==0 then SummonBossStuckSince=tick() end
            if tick()-SummonBossStuckSince>SUMMON_STUCK_TIMEOUT then
                Notify.new({Title="Summon Boss",Content="No targets for "..SUMMON_STUCK_TIMEOUT.."s — returning to farm",Duration=4,Icon=ICON})
                ExitSummonBossMode()
                return
            end
            -- Clear committed for current-island bosses not alive; only count fail if grace period elapsed
            for _,b in ipairs(SummonBosses) do
                if SummonBossCommitted[b.Name] and GetSummonBossIsland(b.Name)==SummonBossCurrentIsland and not CheckSummonBoss(b.Name) then
                    local lastFire=SummonBossLastFire[b.Name] or 0
                    local lastKill=SummonBossLastKill[b.Name] or 0
                    local elapsed=tick()-math.max(lastFire,lastKill)
                    if elapsed>=SUMMON_GRACE then
                        SummonBossCommitted[b.Name]=nil
                        SummonBossFailCount[b.Name]=(SummonBossFailCount[b.Name] or 0)+1
                        if SummonBossFailCount[b.Name]>=3 then
                            BSF[b.Name]=false
                            local tgl=BSFToggle[b.Name]
                            if tgl then
                                pcall(function() tgl:SetValue(false) end)
                            end
                            local dsp=SummonBossDisplay[b.Name] or b.Name
                            Notify.new({Title="Summon Failed",Content=dsp.." disabled — no materials?",Duration=5,Icon=ICON})
                        end
                    end
                end
            end
            -- If no bosses left enabled, bail out
            if not HasAnySummonBossEnabled() then
                task.wait(0.3) return
            end
            -- Only re-summon bosses that aren't in cooldown grace period
            for _,b in ipairs(SummonBosses) do
                if BSF[b.Name] and not SummonBossCommitted[b.Name] and GetSummonBossIsland(b.Name)==SummonBossCurrentIsland then
                    local lastKill=SummonBossLastKill[b.Name] or 0
                    if tick()-lastKill>=SUMMON_GRACE then
                        FireSummonBoss(b.Name)
                        SummonBossOrder=SummonBossOrder+1
                        SummonBossCommitted[b.Name]=SummonBossOrder
                        task.wait(0.1)
                    end
                end
            end
            local nextName,_=AcquireSummonBossFast(nil,1.0)
            SummonBossTarget=nextName
            if SummonBossTarget then SummonBossStuckSince=0 end
            if not SummonBossTarget then
                -- Check if there are bosses on other islands
                for _,b in ipairs(SummonBosses) do
                    if BSF[b.Name] and GetSummonBossIsland(b.Name)~=SummonBossCurrentIsland then
                        SummonBossTPDone=false LastSummonBossTP=0
                        ClearTgt()
                        return
                    end
                end
                task.wait(0.5)
            end
            return
        end
        SummonBossStuckSince=0
        Notify.new({Title="Summon Boss: "..(SummonBossDisplay[SummonBossTarget] or SummonBossTarget),Content="Attacking!",Duration=2,Icon=ICON})
    end
    -- Phase 3: check if target needs island switch
    local targetIsland=GetSummonBossIsland(SummonBossTarget)
    if targetIsland~=SummonBossCurrentIsland then
        SummonBossTPDone=false LastSummonBossTP=0
        ClearTgt()
        return
    end
    -- Phase 4: fight
    local model=CheckSummonBoss(SummonBossTarget)
    if not model then
        task.wait(0.25)
        model=CheckSummonBoss(SummonBossTarget)
        if model then CurTarget=model return end
        local deadName=SummonBossTarget
        local deadDisplay=SummonBossDisplay[deadName] or deadName
        BossKills=BossKills+1 Kills=Kills+1 KillCount=KillCount+1
        Notify.new({Title="Killed "..deadDisplay,Content="Successfully killed "..deadDisplay,Duration=4,Icon=ICON})
        SummonBossCommitted[deadName]=nil
        SummonBossLastKill[deadName]=tick()
        SummonBossTarget=nil ClearTgt()
        SummonBossStuckSince=0
        -- Re-summon the killed boss if still enabled
        if BSF[deadName] and GetSummonBossIsland(deadName)==SummonBossCurrentIsland then
            task.wait(0.3)
            FireSummonBoss(deadName)
            SummonBossOrder=SummonBossOrder+1
            SummonBossCommitted[deadName]=SummonBossOrder
        end
        local nextName,nextModel=AcquireSummonBossFast(deadName,1.5)
        SummonBossTarget=nextName
        if nextModel then CurTarget=nextModel end
        return
    end
    local bossPos=ModelPos(model)
    if not bossPos or bossPos.Y<-30 then task.wait(0.15) return end
    local _hrp=PlayerHRP()
    if _hrp and (bossPos-_hrp.Position).Magnitude>600 then
        SummonBossTPDone=false LastSummonBossTP=0
        ClearTgt()
        return
    end
    CurTarget=model
    TweenTo(model)
    Attack(model)
    if F.AutoEquip and tick()-LastEquip>3 then LastEquip=tick() local eq=GetTool() if not eq or eq.Name:lower()=="combat" then EquipSword() end end
end
