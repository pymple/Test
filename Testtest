                SummonBossFight=true BossFight=false BossTargetName=nil BossTPDone=false SummonBossTPDone=false LastSummonBossTP=0 SummonBossCurrentIsland=nil SummonBossOrder=0 SummonBossFailCount={} SummonBossLastFire={} SummonBossLastKill={} SummonBossStuckSince=0 ClearTgt() HoverPos=nil CurIsland=nil IslandTPd=false
                Notify.new({Title="Summon Boss Mode",Content="Starting summon boss cycle",Duration=3,Icon=ICON})
            end
            if SummonBossFight then DoSummonBossTick() task.wait(0.1) break end
            if not F.AutoFarmLevel then task.wait(0.3) break end
            if F.BossEnabled and not BossFight then
                local nextName=PickNextBossName()
                if nextName then
                    BossFight=true BossTargetName=nextName BossTPDone=false LastBossTP=0 BossCurrentIsland=GetBossIsland(nextName) ClearTgt() HoverPos=nil CurIsland=nil IslandTPd=false
                    Notify.new({Title="BOSS: "..GetBossDisplay(nextName),Content="On "..(BossCurrentIsland or "?").." | Stopping farm",Duration=4,Icon=ICON})
                end
            end
            if BossFight then DoBossTick() task.wait(0.1) break end
            DoFarmTick()
            task.wait(0.1)
        until true
    end
end)
