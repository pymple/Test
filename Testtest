    local out={}
    local function checkModel(m)
        if m:IsA("Model") and not IsPlayer(m) and not IsBoss(m.Name) then
            local hm=GetHum(m)
            if hm and hm.Health>0 and not ShouldIgnore(m.Name) then
                if MatchEnemy(m.Name,island) then table.insert(out,m) end
            end
        end
    end
    for _,child in ipairs(nf:GetChildren()) do
        if child:IsA("Folder") then for _,m in ipairs(child:GetChildren()) do checkModel(m) end
        else checkModel(child) end
    end
    return out
