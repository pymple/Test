local function NearestFrom(list)
    local hrp=PlayerHRP() if not hrp then return nil end
    local myY=hrp.Position.Y
    local best,bd=nil,math.huge
    for _,e in ipairs(list) do local p=ModelPos(e) if p and math.abs(p.Y-myY)<150 then local d=(p-hrp.Position).Magnitude if d<bd then bd=d best=e end end end
    return best
end
